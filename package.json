{
  "name": "xagents",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"bun run dev:server\" \"bun run dev:web\"",
    "dev:server": "tsx watch apps/server/src/main.ts",
    "start:server": "node --experimental-strip-types apps/server/src/main.ts",
    "dev:web": "cd apps/web && bun run dev",
    "build:web": "cd apps/web && bun run build",
    "typecheck": "for d in packages/* apps/*; do [ -f \"$d/tsconfig.json\" ] && (echo \"# $d\" && tsc --noEmit -p \"$d/tsconfig.json\") || true; done",
    "test": "bun test",
    "test:integration": "vitest run --dir packages --config vitest.config.ts",
    "test:e2e": "playwright test",
    "db:migrate": "cd packages/db && bun run migrate"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "tsx": "^4.19.2",
    "@types/node": "^24.0.0"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^1.0.0",
    "ai": "^7.0.26",
    "eve": "^0.23.0",
    "just-bash": "^3.1.0",
    "microsandbox": "^0.6.6",
    "zod": "^4.4.3"
  }
}
