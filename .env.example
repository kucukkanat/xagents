# --- Server ---
PORT=8787
NODE_ENV=development

# --- Database ---
# SQLite file path (relative to repo root)
DATABASE_PATH=./data/xagents.sqlite

# --- Agent runtime workspace (materialized eve projects live here) ---
AGENTS_WORKSPACE_DIR=./.agents-workspace

# --- Sandbox backend: microsandbox | justbash | docker ---
SANDBOX_BACKEND=microsandbox

# --- LLM providers ---
# Providers, models, and their API keys are now managed from the admin console
# (Providers tab) and stored encrypted in the DB. The two vars below are only
# used to SEED the DeepSeek provider on first boot, so existing setups keep
# working; after that, manage everything from the console.
#
# Master key for encrypting provider secrets at rest (AES-256-GCM). REQUIRED to
# store/use provider API keys. Any non-empty value works (a passphrase is
# stretched to a key); for production prefer a random key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))" | pbcopy
SECRETS_KEY=
# Optional legacy key, sealed into the seeded DeepSeek provider on first boot.
DEEPSEEK_API_KEY=sk-your-key-here

# --- Super-admin console (monitoring + governance) ---
# Shared secret gating /api/admin/*. Unset/empty = console disabled (routes 404,
# no metrics sampling). Set it to enable the Admin nav + console; the web prompts
# for this value and sends it as a bearer token.
ADMIN_TOKEN=
# Metrics sampler cadence + retention (optional; sensible defaults shown).
METRICS_SAMPLE_INTERVAL_MS=15000
METRICS_RETENTION_DAYS=7
METRICS_HISTORY_RETENTION_DAYS=30
